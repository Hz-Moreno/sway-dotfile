{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 12,
    "modules-left": ["sway/workspaces"],
    "modules-center": [],
    "modules-right": ["temperature", "cpu", "memory", "clock", "custom/recorder"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "format-icons": {
            "default": ""
        }
    },

    "cpu": {
        "format": "  {usage}%",
        "interval": 2,
        "tooltip": false
    },

    "memory": {
        "format": "  {percentage}%",
        "interval": 5,
        "tooltip": true
    },

    "temperature": {
   "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format": " {temperatureC}°C",
    "format-critical": " {temperatureC}°C",
    "tooltip": true 
    },

    "clock": {
        "format": "{:%H:%M  %d/%m/%Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "custom/recorder": {
    "format": "{}",
    "return-type": "json",
    "interval": 1,
    "exec": "$HOME/dotfiles/scripts/recorder-status.sh"
}
}
